# ============================================================
# Client Onboarding Portal - Server Environment
# Copy this file to .env and fill in the values.
# NEVER commit the real .env file.
# ============================================================

# Port the API listens on
PORT=4000

# Comma-separated list of allowed frontend origins (CORS)
ALLOWED_ORIGIN=http://localhost:5173

# The Google Drive folder that holds all client folders
DRIVE_ROOT_FOLDER_ID=1ctJI9bO9hrB8PVBkLsvra3QqQFBJjG9K

# Maximum size per uploaded file, in megabytes
MAX_UPLOAD_MB=500

# Local file containing the selectable color palettes (coolors.co CSS
# exports; .docx, .txt or .css). Defaults to "Color Combinations.docx"
# in the project root - set this only to use a different file.
COLOR_PALETTES_FILE=

# ------------------------------------------------------------
# Google OAuth 2.0 credentials.
# The server acts as YOUR Google account (files are owned by you and use
# your storage quota - required for personal Gmail accounts).
#
#   1. Google Cloud Console -> APIs & Services -> Credentials ->
#      Create credentials -> OAuth client ID.
#      For a "Web application" client, add this Authorized redirect URI:
#        http://localhost:3000/oauth2callback
#   2. Paste ONLY the client ID and the raw client_secret value below
#      (never the whole OAuth JSON file).
#   3. Run "npm run get-token" once - a browser opens, you approve access,
#      and the refresh token is saved here automatically.
# ------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
